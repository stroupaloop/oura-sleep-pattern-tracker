# App auth (magic link login)
NEXTAUTH_SECRET=             # Run: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
RESEND_API_KEY=              # From https://resend.com/api-keys
EMAIL_FROM=noreply@resend.dev
ALLOWED_EMAILS=              # Comma-separated, e.g. you@email.com,them@email.com

# Oura OAuth (ring data connection)
OURA_CLIENT_ID=              # From https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_SECRET=          # From https://cloud.ouraring.com/oauth/applications

# Database (Turso)
TURSO_DATABASE_URL=           # From https://turso.tech dashboard, e.g. libsql://your-db.turso.io
TURSO_AUTH_TOKEN=             # From: turso db tokens create your-db-name

# Twilio (SMS notifications - optional)
TWILIO_ACCOUNT_SID=           # From https://console.twilio.com
TWILIO_AUTH_TOKEN=            # From https://console.twilio.com
TWILIO_PHONE_NUMBER=          # Your Twilio phone number, e.g. +1234567890

# Cron
CRON_SECRET=                  # Run: openssl rand -base64 32
